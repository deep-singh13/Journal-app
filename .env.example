# Copy this to .env and fill in your values

# Neon connection string — from Neon dashboard → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Password to protect your journal (anyone who knows this can access your data)
AUTH_PASSWORD=choose-a-strong-password

# Leave as-is for production; omit (or set to "development") locally
NODE_ENV=production
